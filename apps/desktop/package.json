{
  "name": "@video-editor/desktop",
  "version": "0.0.1",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@video-editor/ai": "workspace:*",
    "@video-editor/database": "workspace:*",
    "@video-editor/export": "workspace:*",
    "@video-editor/ffmpeg": "workspace:*",
    "@video-editor/transcript": "workspace:*",
    "@video-editor/types": "workspace:*",
    "@video-editor/ui": "workspace:*",
    "@video-editor/utils": "workspace:*",
    "@video-editor/whisper": "workspace:*",
    "@vidstack/react": "^1.15.6",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.0",
    "lucide-react": "^1.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.clipper.app",
    "productName": "Clipper",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "../../resources/",
        "to": "resources/"
      }
    ]
  }
}
