{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "out",
    "composite": true,
    "noEmit": true,
    "rootDir": "../../",
    "skipLibCheck": true,
    "paths": {
      "@main/*": ["./src/main/*"],
      "@video-editor/*": ["../../packages/*/dist/index.d.ts"]
    }
  },
  "include": ["src/main/**/*", "src/preload/**/*"]
}
